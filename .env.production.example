# Resume Generator Pro — Production Environment
# Copy to .env.production and fill in real values

# ─── AI Model ────────────────────────────────────
RESUME_USE_AI=1
RESUME_MODEL_PROVIDER=gemini          # gemini | openai | anthropic | glm | kimi | minimax | grok | qwen | doubao | other
RESUME_API_KEY=your-api-key-here
RESUME_MODEL_NAME=                    # leave blank for provider default
RESUME_API_BASE_URL=                  # custom base URL (optional)

# ─── Auth / Billing (optional) ───────────────────
# AUTH_BILLING_ENFORCE=0
# AUTH_BILLING_BASE_URL=http://auth:8080
# AUTH_BILLING_SERVICE_SECRET=change-me
